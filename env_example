# This is an example .env file for the odtiles Docker setup.
# Copy this file to .env and edit the values as needed.

COMPOSE_PROJECT_NAME=odtiles

SERVER_NAME=localhost
SERVER_ADMIN=admin@localhost
URL=https://example.jp
ALLOWED_HOSTS=localhost,host.example.jp,192.168.0.1
UWSGI_WORKERS=8
UWSGI_PORT=8080
TILE_SOURCE_FOLDER=/var/odtiles/tilesrc
TILE_OUTPUT_FOLDER=/var/odtiles/tileout
WMS_OUTPUT_FOLDER=/var/odtiles/wmsout
MAX_AGE=3600
MAX_AGE_LIVE=60
